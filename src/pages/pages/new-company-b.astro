            // }, observerOptions);

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        
                        // 1. Reset all tabs to default state
                        navItems.forEach(item => {
                            // Clear the dynamic inline colors
                            item.style.backgroundColor = '';
                            item.style.color = '';
                            
                            // Remove active indentation (Fixed: changed 'pl-8' to 'md:pl-8')
                            item.classList.remove('md:pl-8');
                            
                            // Add default Tailwind colors back
                            item.classList.add('bg-gray-200', 'text-gray-600');
                        });

                        // 2. Highlight the active tab
                        const activeId = entry.target.id;
                        const activeTab = document.querySelector(`.phase-tab[data-target="${activeId}"]`);
                        
                        if (activeTab) {
                            const bgKey = activeTab.getAttribute('bg-color');
                            const textKey = activeTab.getAttribute('text-color');

                            // Remove default Tailwind colors so they don't conflict
                            activeTab.classList.remove('bg-gray-200', 'text-gray-600');
                            
                            // Apply dynamic CMS colors via inline styles
                            activeTab.style.backgroundColor = bgKey;
                            activeTab.style.color = textKey;
                            
                            // Apply active indentation
                            activeTab.classList.add('md:pl-8');
                            
                            // On mobile, scroll the horizontal nav to show the active tab
                            if (window.innerWidth <= 768) {
                                activeTab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                            }
                        }
                    }
                });
            }, observerOptions);

            // Start observing each section
            sections.forEach(section => {
                observer.observe(section);
            });
        });

        document.addEventListener("DOMContentLoaded", () => {
            webform('#contact-us', {
                callback: () => {
                    gtag('event', 'generate_lead', {
                    form_name: 'Contact Page Form'
                    });
                }
            })});
    </script>
