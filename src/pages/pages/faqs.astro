---
import { defaultLang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getEntry } from 'astro:content';

const { slug } = Astro.params;
const lang = "en"; // Astro.currentLocale || defaultLang;
const t = useTranslations(lang);

---
<Layout lang={lang} slug=`pages`>


<section class="bg-gray-50 min-h-screen py-16 px-6">
  <div class="max-w-4xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Frequently Asked Questions
      </h1>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Below are answers to common questions about our services, process, and what you can expect when working with us.
      </p>
    </div>

    <!-- FAQ List -->
      <details class="group border-b border-gray-300 pb-8 mt-3">
        <summary class="flex justify-between items-center cursor-pointer text-lg font-medium list-none">
          Can a foreign investor own 100% of a Saudi company?
          <span class="transition-transform duration-300 group-open:rotate-180">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" />
            </svg>
          </span>
        </summary>
        <p class="mt-3 !text-gray-800 leading-relaxed">
          Yes — in most sectors. Saudi Arabia opened the majority of commercial activities to full foreign ownership under Vision 2030 reforms. MISA's approved activities list governs eligibility by sector. Some activities still require a Saudi partner; we assess your specific activity at the outset.
        </p>
      </details>

      <!-- Example of a modern transition -->
<details class="group transition-all duration-500 overflow-hidden">
  <summary class="cursor-pointer list-none">Click to expand</summary>
  <div class="grid grid-rows-[0fr] transition-all duration-500 group-open:grid-rows-[1fr]">
    <div class="overflow-hidden">
      Your animated content goes here.
    </div>
  </div>
</details>


