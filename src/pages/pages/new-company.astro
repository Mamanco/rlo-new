    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const sections = document.querySelectorAll('.phase-section');
            const navItems = document.querySelectorAll('.phase-tab');

            // Define the active color palettes mapped to the data-color attribute
            // const colorMap = {
            //     'phase-1': { bg: 'bg-emerald-100', text: 'text-emerald-900' },
            //     'phase-2': { bg: 'bg-blue-100', text: 'text-blue-900' },
            //     'phase-3': { bg: 'bg-purple-100', text: 'text-purple-900' },
            //     'phase-4': { bg: 'bg-orange-100', text: 'text-orange-900' },
            //     'phase-5': { bg: 'bg-teal-100', text: 'text-teal-900' }
            // };

            // Set up the Intersection Observer
            const observerOptions = {
                root: null,
                // Triggers when the section is roughly in the middle of the screen
                rootMargin: '-30% 0px -50% 0px', 
                threshold: 0
            };

            // const observer = new IntersectionObserver((entries) => {
            //     entries.forEach(entry => {
            //         if (entry.isIntersecting) {
                        
            //             // 1. Reset all tabs to default state
            //             navItems.forEach(item => {
            //                 const bgKey = item.getAttribute('bg-color');
            //                 const textKey = item.getAttribute('text-color');
                            
            //                 // Remove active colors
            //                 item.classList.remove(`bg-[${bgKey}]`, `text-[${textKey}]`, 'pl-8');
                            
            //                 // Add default colors
            //                 item.classList.add('bg-gray-200', 'text-gray-600');
            //             });

            //             // 2. Highlight the active tab
            //             const activeId = entry.target.id;
            //             const activeTab = document.querySelector(`.phase-tab[data-target="${activeId}"]`);
                        
            //             if (activeTab) {
            //               const bgKey = activeTab.getAttribute('bg-color');
            //               const textKey = activeTab.getAttribute('text-color');

            //               // Remove default colors
            //               activeTab.classList.remove('bg-gray-200', 'text-gray-600');
                          
            //               // Apply active colors and a slight indentation for desktop
            //               activeTab.classList.add(`bg-[${bgKey}]`, `text-[${textKey}]`, 'md:pl-8');
                          
            //               // On mobile, scroll the horizontal nav to show the active tab
            //               if(window.innerWidth <= 768) {
            //                   activeTab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
            //               }
            //             }
            //         }
            //     });
            // }, observerOptions);

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        
                        // 1. Reset all tabs to default state
                        navItems.forEach(item => {
                            // Clear the dynamic inline colors
                            item.style.backgroundColor = '';
                            item.style.color = '';
                            
                            // Remove active indentation (Fixed: changed 'pl-8' to 'md:pl-8')
                            item.classList.remove('md:pl-8');
                            
                            // Add default Tailwind colors back
                            item.classList.add('bg-gray-200', 'text-gray-600');
                        });

                        // 2. Highlight the active tab
                        const activeId = entry.target.id;
                        const activeTab = document.querySelector(`.phase-tab[data-target="${activeId}"]`);
                        
                        if (activeTab) {
                            const bgKey = activeTab.getAttribute('bg-color');
                            const textKey = activeTab.getAttribute('text-color');

                            // Remove default Tailwind colors so they don't conflict
                            activeTab.classList.remove('bg-gray-200', 'text-gray-600');
                            
                            // Apply dynamic CMS colors via inline styles
                            activeTab.style.backgroundColor = bgKey;
                            activeTab.style.color = textKey;
                            
                            // Apply active indentation
                            activeTab.classList.add('md:pl-8');
                            
                            // On mobile, scroll the horizontal nav to show the active tab
                            if (window.innerWidth <= 768) {
                                activeTab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                            }
                        }
                    }
                });
            }, observerOptions);

            // Start observing each section
            sections.forEach(section => {
                observer.observe(section);
            });
        });

        document.addEventListener("DOMContentLoaded", () => {
            webform("#contact-us");
        });
    </script>
    <script is:inline src="/static/assets/js/webform.js"></script>
