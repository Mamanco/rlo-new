---
import { defaultLang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getEntry } from 'astro:content';

const { slug } = Astro.params;
const lang = "en"; // Astro.currentLocale || defaultLang;
const t = useTranslations(lang);

const phaseList = await getCollection("new_company_phases");
const taskList = await getCollection("new_company_tasks");

const pahseEntryList = phaseList
	.filter(entry => entry.slug.split("/").includes(lang)).
	sort((a,b) => a.data.order - b.data.order);

// 3. Filter tasks by language (optional, depending on your folder structure)
const langTasks = taskList.filter(task => task.slug.split("/").includes(lang));

// 4. Create the nested structure
const phasesWithTasks = await Promise.all(
  pahseEntryList.map(async (phase) => {
    // 1. Find all tasks belonging to this phase
    const phaseTasks = langTasks
      .filter(task => phase.slug.split("/").includes(task.data.phase)) 
      .sort((a, b) => a.data.order - b.data.order);

    // console.log(phase.slug, phaseTasks);

    // 2. Await the render() function for each task to get its Markdown Content
    const tasksWithContent = await Promise.all(
      phaseTasks.map(async (task) => {
        const { Content } = await task.render();
        return {
          ...task,
          Content // Attach the Astro component directly to the task object
        };
      })
    );

    // 3. Return the phase with the injected, fully-rendered tasks array
    return {
      ...phase,
      tasks: tasksWithContent
    };
  })
);
